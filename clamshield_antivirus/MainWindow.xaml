<Window x:Class="clamshield_antivirus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:clamshield_antivirus"
        xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
        xmlns:views="clr-namespace:clamshield_antivirus.Views"
        xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MainWindow.Title]}" Height="700" Width="1020"
        MinWidth="820" MinHeight="580"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="4" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ScanViewModel}">
            <views:ScanView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EngineViewModel}">
            <views:EngineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <views:EventsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuarantineViewModel}">
            <views:QuarantineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProtectorViewModel}">
            <views:ProtectorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>
    </Window.Resources>

    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="BorderThickness" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar column -->
                <ColumnDefinition Width="200"/>
                <!-- Separator column -->
                <ColumnDefinition Width="1"/>
                <!-- Content column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Panel (extends to the very top) -->
            <Grid Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
                <Grid.RowDefinitions>
                    <!-- Drag Spacer Row -->
                    <RowDefinition Height="40"/>
                    <!-- Brand Header Row -->
                    <RowDefinition Height="Auto"/>
                    <!-- Menu Row -->
                    <RowDefinition Height="*"/>
                    <!-- Footer Row -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Transparent spacer to allow dragging the window by the top of the sidebar -->
                <Border Grid.Row="0" Background="Transparent"/>

                <!-- Brand header -->
                <StackPanel Grid.Row="1" Margin="20,8,20,16" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="ClamUI" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Windows Protection" FontSize="10" Foreground="{StaticResource DimTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sidebar Navigation Menu -->
                <ListBox Grid.Row="2" 
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                         Style="{StaticResource SidebarListBox}"
                         ItemContainerStyle="{StaticResource SidebarItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavigationItem}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Icon}" FontSize="15" Width="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontWeight="Medium" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Sidebar footer / version info -->
                <StackPanel Grid.Row="3" Margin="16,12" Orientation="Vertical">
                    <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MainWindow.Version]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MainWindow.PoweredBy]}" FontSize="10" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Vertical separator -->
            <Rectangle Grid.Column="1" Fill="{StaticResource SeparatorBrush}" Width="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Main Content Area -->
            <Grid Grid.Column="2" Background="{StaticResource WindowBgBrush}">
                <Grid.RowDefinitions>
                    <!-- Custom Title Bar Row -->
                    <RowDefinition Height="40"/>
                    <!-- Page Content Row -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom Title Bar Header -->
                <Grid Grid.Row="0" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Current page title displayed in title bar -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="{Binding SelectedNavigationItem.Title}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DimTextBrush}"/>
                    </StackPanel>

                    <!-- Window Control Buttons (Minimize, Maximize, Close) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button x:Name="BtnMinimize" 
                                Style="{StaticResource TitleBarButtonStyle}" 
                                Content="─" 
                                Click="MinimizeButton_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="BtnMaximize" 
                                Style="{StaticResource TitleBarButtonStyle}" 
                                Content="▢" 
                                Click="MaximizeButton_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="BtnClose" 
                                Style="{StaticResource TitleBarCloseButtonStyle}" 
                                Content="✕" 
                                Click="CloseButton_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>

                <!-- Page Content (shifted down below title bar) -->
                <Grid Grid.Row="1">
                    <ContentControl Content="{Binding CurrentViewModel}" Focusable="False"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
