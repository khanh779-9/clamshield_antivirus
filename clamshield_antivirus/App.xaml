<Application x:Class="clamshield_antivirus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:clamshield_antivirus"
             xmlns:conv="clr-namespace:clamshield_antivirus.Converters"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:InverseBoolConverter x:Key="InvBool"/>
            <conv:FileSizeConverter x:Key="FileSizeConv"/>
            <conv:StatusToColorConverter x:Key="StatusToColor"/>
            <conv:StatusToIconConverter x:Key="StatusToIcon"/>
            <conv:StringToVisibilityConverter x:Key="StringToVis"/>
            <conv:CountToVisibilityConverter x:Key="CountToVis"/>
            <conv:StringContainsConverter x:Key="StringContainsConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
