<UserControl x:Class="clamshield_antivirus.Views.ProtectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:ProtectorViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Real-Time Protector" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="Continuous system-wide filesystem protection running with Administrator privileges" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Status & Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Shield Status & Active Toggle -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Large Shield Status Icon -->
                    <TextBlock Grid.Column="0" Text="🛡️" FontSize="42" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <!-- Status Text -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Real-Time Shield Status" Style="{StaticResource CardSubtitle}"/>
                        <TextBlock Text="{Binding CurrentStatusText}" FontSize="20" FontWeight="Bold" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CardTitle}">
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Active System Shield (Admin)" Foreground="{StaticResource DimTextBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Toggle Switch Button -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <ToggleButton Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding IsRunning, Mode=TwoWay}" Width="50" Height="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 2: Stats Counters -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Stat 1: Files Scanned -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Files Checked" Style="{StaticResource CardSubtitle}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding TotalScanned}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Grid.Row="1" Background="{StaticResource SeparatorBrush}" Margin="0,4"/>

                    <!-- Stat 2: Threats Blocked -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Threats Blocked" Style="{StaticResource CardSubtitle}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding ThreatsBlocked}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Lower Section: Active Dirs & Real-time Console Logs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Monitored Drives -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Monitored Areas" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
                    <Grid>
                        <!-- When monitor is running, show drives list -->
                        <ListBox ItemsSource="{Binding MonitoredPaths}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,6">
                                        <TextBlock Text="💾" FontSize="18" Margin="0,0,10,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="System Drive (Full Access)" FontSize="10" Foreground="{StaticResource DimTextBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- When monitor is disabled -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10"
                                    Visibility="{Binding IsRunning, Converter={StaticResource InvBoolToVis}}">
                            <TextBlock Text="⚠️" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Shield Offline" Style="{StaticResource CardTitle}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="Enable Real-Time Protection to begin monitoring system drives." 
                                       Style="{StaticResource CardSubtitle}" TextAlignment="Center" MaxWidth="180" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Panel: Activity Logs Console -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Recent Activity Log" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding ActivityLogs}"
                         Background="{StaticResource SidebarBgBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="11"
                         Padding="6"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Padding" Value="2"/>
                            <Style.Triggers>
                                <!-- Highlight warning logs in red -->
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource StringContainsConverter}, ConverterParameter='[WARNING]'}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
