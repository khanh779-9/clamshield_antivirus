<UserControl x:Class="clamshield_antivirus.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:QuarantineViewModel}">

    <UserControl.Resources>
        <Style x:Key="RowText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header + summary card in container -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🛡️" Style="{StaticResource CardIcon}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.Title]}" Style="{StaticResource HeadingText}" FontSize="18"/>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ClearAll]}" Style="{StaticResource DangerButton}" Padding="12,7"
                            Command="{Binding ClearAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ClearOld]}" Style="{StaticResource SecondaryButton}" Padding="12,7"
                            Command="{Binding ClearOldCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Stats + Search + Delete Selected -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalSizeText}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="•" Foreground="{StaticResource DimTextBrush}" Margin="8,0"/>
                    <TextBlock Text="{Binding ItemCountText}" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.DeleteSelected]}" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="11"
                        Command="{Binding DeleteSelectedCommand}" Margin="16,0,0,0" Height="28"/>

                <TextBox Grid.Column="2" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Tag="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.SearchTag]}" Margin="16,0,0,0"
                         BorderBrush="{StaticResource BorderBrush}" Height="28" VerticalContentAlignment="Center"/>

                <Button Grid.Column="3" Content="⟳" Style="{StaticResource IconButton}" FontSize="14" Margin="6,0,0,0"
                        Command="{Binding RefreshCommand}" Width="28" Height="28"/>
            </Grid>
        </Border>

        <!-- Row 2: Table -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource SidebarBgBrush}"
                    Visibility="{Binding HasEntries, Converter={StaticResource InvBoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="40" Opacity="0.35" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.NoFiles]}" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.NoFilesDesc]}" Style="{StaticResource CardSubtitle}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Table -->
            <Border Style="{StaticResource CardStyle}" Padding="0"
                    Visibility="{Binding HasEntries, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <ListView ItemsSource="{Binding Entries}"
                               SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                               Background="Transparent" BorderThickness="0"
                               ScrollViewer.HorizontalScrollBarVisibility="Auto"
                               ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <!-- Column 0: Checkbox -->
                                <GridViewColumn Width="40">
                                    <GridViewColumnHeader HorizontalContentAlignment="Center">
                                        <CheckBox IsChecked="{Binding SelectAllChecked}" 
                                                  Focusable="False" HorizontalAlignment="Center"/>
                                    </GridViewColumnHeader>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <CheckBox IsChecked="{Binding IsSelected}" 
                                                      Focusable="False" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 1: File Name -->
                                <GridViewColumn Header="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ColFileName]}" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}" Style="{StaticResource RowText}"
                                                       FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 2: Original Location -->
                                <GridViewColumn Header="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ColOriginalPath]}" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <TextBlock Text="{Binding OriginalPath}" ToolTip="{Binding OriginalPath}" Style="{StaticResource RowText}"
                                                       Foreground="{StaticResource SecondaryTextBrush}" FontSize="11"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 3: Threat Name -->
                                <GridViewColumn Header="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ColThreatName]}" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <TextBlock Text="{Binding ThreatName}" ToolTip="{Binding ThreatName}" Style="{StaticResource RowText}"
                                                       Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 4: Date Isolated -->
                                <GridViewColumn Header="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ColDateIsolated]}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <TextBlock Text="{Binding QuarantineDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource RowText}"
                                                       Foreground="{StaticResource DimTextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 5: Size -->
                                <GridViewColumn Header="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.ColSize]}" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConv}}" Style="{StaticResource RowText}"
                                                       Foreground="{StaticResource DimTextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 6: Actions -->
                                <GridViewColumn Header="" Width="135">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:QuarantineEntry}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.Restore]}" Style="{StaticResource RowActionButton}"
                                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.Delete]}" Style="{StaticResource RowActionButton}"
                                                        Background="#44D32F2F" Foreground="{StaticResource ErrorBrush}"
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 3: Detail bar -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource AccentBrush}" Margin="0,12,0,0" Padding="12"
                Visibility="{Binding IsEntrySelected, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.SelectedLabel]}" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text=" " FontSize="13"/>
                        <TextBlock Text="{Binding SelectedEntry.ThreatName}" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedEntry.OriginalPath}" FontSize="11" Foreground="{StaticResource DimTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.RestoreFile]}" Style="{StaticResource AccentButton}" Padding="14,7" Margin="0,0,8,0"
                            Command="{Binding RestoreCommand}"/>
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Quarantine.DeletePermanently]}" Style="{StaticResource DangerButton}" Padding="14,7"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
