<UserControl x:Class="clamshield_antivirus.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:clamshield_antivirus.Views"
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:ScanViewModel}"
             AllowDrop="True" Drop="UserControl_Drop">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Title Section -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.Title]}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding BackendText}" Style="{StaticResource StatusText}" Foreground="{StaticResource DimTextBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Core Working Area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Configuration Frame (Profile Selector) -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.ProfileLabel]}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" Margin="12,0,0,0" 
                              ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsScanning, Converter={StaticResource InvBool}}"/>
                </Grid>
            </Border>

            <!-- Targets list / Dropzone -->
            <Grid Grid.Row="1">
                <!-- Empty Target Placeholder (Dropzone visual) -->
                <Border Style="{StaticResource CardStyle}" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource SidebarBgBrush}"
                        Visibility="{Binding HasTargets, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                        <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" Opacity="0.35"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.NoTargets]}" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.NoTargetsDesc]}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- List of selected paths -->
                <ListBox ItemsSource="{Binding Targets}" 
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding HasTargets, Converter={StaticResource BoolToVis}}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type sys:String}">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,0,6" Background="{StaticResource SurfaceBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="📄" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13"/>
                                    <Button Grid.Column="2" Content="✕" 
                                            Style="{StaticResource SmallIconButton}" 
                                            Command="{Binding DataContext.RemoveTargetCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding DataContext.IsScanning, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource InvBool}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Bottom Action bar / Progress Overlay / Result Overlay -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Control Buttons (Standard state: not scanning AND no results) -->
            <Grid Grid.Row="0" Visibility="{Binding IsControlPanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.AddFiles]}" Style="{StaticResource SecondaryButton}" Command="{Binding AddFileCommand}" Margin="0,0,6,0"/>
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.AddFolder]}" Style="{StaticResource SecondaryButton}" Command="{Binding AddFolderCommand}" Margin="0,0,6,0"/>
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.ClearAll]}" Style="{StaticResource DangerButton}" Command="{Binding ClearTargetsCommand}" 
                            Visibility="{Binding HasTargets, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.EicarTest]}" Style="{StaticResource SecondaryButton}" Command="{Binding EicarTestCommand}" Margin="0,0,6,0"/>
                    <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.StartScan]}" Style="{StaticResource AccentButton}" Command="{Binding StartScanCommand}" IsEnabled="{Binding CanStartScan}"/>
                </StackPanel>
            </Grid>

            <!-- Scanning progress state -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource AccentBrush}" Padding="14"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Progress.StatusText}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Progress.FilesScanned, StringFormat='Scanned: {0}'}" Style="{StaticResource CardSubtitle}" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource AccentProgressBar}" Margin="0,10" 
                                 IsIndeterminate="{Binding Progress.IsIndeterminate}"
                                 Value="{Binding Progress.ProgressPercentage}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Progress.CurrentFile}" FontSize="11" Foreground="{StaticResource DimTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.Cancel]}" Style="{StaticResource DangerButton}" Padding="12,6" Command="{Binding CancelScanCommand}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Results display (Replaces control buttons when available) -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="16"
                    Visibility="{Binding IsResultAvailable, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderThickness="1"
                            Background="{Binding Result.Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_bg'}"
                            BorderBrush="{Binding Result.Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_border'}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Result.Status, Converter={StaticResource StatusToIcon}}" 
                                       Foreground="{Binding Result.Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}"
                                       FontSize="18" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Result.Status, StringFormat='Scan Status: {0}'}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Result.ScanPath, StringFormat='Targets: {0}'}" FontSize="11" Style="{StaticResource CardSubtitle}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding Result.Duration, StringFormat='Time: {0:mm\\:ss}'}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                    </Border>

                    <!-- Stats summaries -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.FilesScanned]}" Style="{StaticResource CardSubtitle}"/>
                            <TextBlock Text="{Binding Result.FilesScanned}" Style="{StaticResource StatNumber}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="22"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.Directories]}" Style="{StaticResource CardSubtitle}"/>
                            <TextBlock Text="{Binding Result.DirectoriesScanned}" Style="{StaticResource StatNumber}" HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="22"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.ThreatsFound]}" Style="{StaticResource CardSubtitle}"/>
                            <TextBlock Text="{Binding Result.ThreatsFound}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"
                                       Foreground="{Binding Result.ThreatsFound, Converter={StaticResource StatusToColor}, ConverterParameter='infected'}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Threats list / Actions -->
                    <StackPanel Grid.Row="2" Visibility="{Binding Result.ThreatsFound, Converter={StaticResource CountToVis}}">
                        <Separator Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.DetectedThreats]}" Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.QuarantineAll]}" Style="{StaticResource AccentButton}" Padding="14,7" Command="{Binding QuarantineAllCommand}" VerticalAlignment="Center"/>
                        </Grid>

                        <ListBox ItemsSource="{Binding Result.Threats}" MaxHeight="150" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ThreatDetail}">
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ThreatName}" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" FontSize="13"/>
                                        <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="{StaticResource DimTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2" 
                                            Background="#2C1E21" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1" 
                                            VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold" Style="{StaticResource StatusText}"/>
                                    </Border>
                                    <Menu Grid.Column="2" Background="Transparent" VerticalAlignment="Center">
                                        <MenuItem Header="⋮" Foreground="{StaticResource PrimaryTextBrush}" FontSize="18" Width="28" Height="28">
                                            <MenuItem Header="Add to Exclusions" Command="{Binding DataContext.ExcludePathCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                        </MenuItem>
                                    </Menu>
                                </Grid>
                            </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- New Scan button row -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Scan.NewScan]}"
                                Style="{StaticResource AccentButton}" Padding="16,8" Command="{Binding DismissResultCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
