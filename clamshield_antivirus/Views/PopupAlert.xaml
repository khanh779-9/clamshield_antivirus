<Window x:Class="clamshield_antivirus.Views.PopupAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
        Title="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MainWindow.Title]}" MinWidth="360" MaxWidth="650" SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="AlertBorder" BorderThickness="1.5"
            Background="{StaticResource CardBgBrush}" CornerRadius="12"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Content Area: Align Icon (Col 0) and Text Details (Col 1) -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Dynamic Icon (Shield/Info/Gear) -->
                <Path Grid.Column="0" Width="24" Height="24" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      x:Name="AlertIcon" Stroke="{StaticResource ErrorBrush}" Fill="Transparent"
                      Data="M 10,1 L 18,4 L 18,10 C 18,15 14,18.5 10,19.5 C 6,18.5 2,15 2,10 L 2,4 Z M 7,7 L 13,13 M 13,7 L 7,13"
                      VerticalAlignment="Top" Margin="0,2,12,0" Stretch="Uniform"/>

                <!-- Content text vertical StackPanel aligned on Column 1 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTitle" Text="Real-Time Threat Blocked"
                               Foreground="{StaticResource ErrorBrush}" FontWeight="Bold" FontSize="14"
                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtLine1" Text="File: malware.exe"
                               Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtLine2" Text="Threat: Win.Test.EICAR"
                               Foreground="{DynamicResource PrimaryTextBrush}" FontSize="11.5" Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtLine3" Text="Action: Quarantined"
                               Foreground="#A6E3A1" FontSize="11.5" FontWeight="Bold" Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- Buttons Row -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Alert.CloseAll]}" Style="{StaticResource SecondaryButton}"
                        Width="80" Height="24" FontSize="11" Padding="0" Margin="0,0,8,0" Click="BtnCloseAll_Click"/>
                <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Alert.Close]}" Style="{StaticResource AccentButton}"
                        Width="65" Height="24" FontSize="11" Padding="0" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
