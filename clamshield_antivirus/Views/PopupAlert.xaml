<Window x:Class="clamshield_antivirus.Views.PopupAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Threat Blocked" Width="360" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1.5" 
            Background="{StaticResource CardBgBrush}" CornerRadius="12"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header with Title and Path Icon -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Shield Icon with Cross in the center (Error) -->
                <Path Grid.Column="0" Width="20" Height="20" StrokeThickness="1.8"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Stroke="{StaticResource ErrorBrush}" Fill="Transparent"
                      Data="M 10,1 L 18,4 L 18,10 C 18,15 14,18.5 10,19.5 C 6,18.5 2,15 2,10 L 2,4 Z M 7,7 L 13,13 M 13,7 L 7,13"
                      VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBlock Grid.Column="1" Text="Real-Time Threat Blocked" 
                           Foreground="{StaticResource ErrorBrush}" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- File info details -->
            <StackPanel Grid.Row="1" Margin="30,8,0,8" VerticalAlignment="Center">
                <TextBlock x:Name="TxtFileName" Text="File: malware.exe" 
                           Foreground="{StaticResource PrimaryTextBrush}" FontSize="12.5" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtThreatName" Text="Threat: Win.Test.EICAR" 
                           Foreground="{StaticResource DimTextBrush}" FontSize="11.5" Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Action: Quarantined" 
                           Foreground="#A6E3A1" FontSize="11.5" FontWeight="Bold" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close All" Style="{StaticResource SecondaryButton}" 
                        Width="80" Height="24" FontSize="11" Padding="0" Margin="0,0,8,0" Click="BtnCloseAll_Click"/>
                <Button Content="Close" Style="{StaticResource AccentButton}" 
                        Width="65" Height="24" FontSize="11" Padding="0" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
