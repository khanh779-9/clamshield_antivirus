<Window x:Class="clamshield_antivirus.Views.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
        mc:Ignorable="d"
        Title="{Binding Caption}"
        SizeToContent="WidthAndHeight"
        MinWidth="380"
        MaxWidth="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.4" ShadowDepth="2"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title / Header -->
                <RowDefinition Height="Auto"/> <!-- Content Body -->
                <RowDefinition Height="Auto"/> <!-- Buttons Footer -->
            </Grid.RowDefinitions>

            <!-- Title bar / Caption -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock x:Name="TitleText" Text="Dialog" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Custom Vector Icon Path -->
                <Path x:Name="IconPath" Grid.Column="0"
                      Width="32" Height="32"
                      StrokeThickness="2.2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Fill="Transparent"
                      VerticalAlignment="Top"
                      Margin="0,0,16,0"/>

                <!-- Message -->
                <TextBlock x:Name="MessageText" Grid.Column="1" Text="Message content goes here." 
                           FontSize="13" Foreground="{StaticResource PrimaryTextBrush}" 
                           TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="18"/>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnOk" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MessageBox.Ok]}" Style="{StaticResource AccentButton}" Width="85" Height="32" Padding="0" Click="BtnOk_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnYes" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MessageBox.Yes]}" Style="{StaticResource AccentButton}" Width="85" Height="32" Padding="0" Margin="0,0,8,0" Click="BtnYes_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnNo" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MessageBox.No]}" Style="{StaticResource SecondaryButton}" Width="85" Height="32" Padding="0" Margin="0,0,8,0" Click="BtnNo_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnCancel" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[MessageBox.Cancel]}" Style="{StaticResource SecondaryButton}" Width="85" Height="32" Padding="0" Click="BtnCancel_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
