<UserControl x:Class="clamshield_antivirus.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Title]}" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Language Card -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.LangTitle]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.LangDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.LangTitle]}" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" 
                                          ItemsSource="{Binding Languages}" 
                                          SelectedItem="{Binding SelectedLanguage}" 
                                          DisplayMemberPath="DisplayName" 
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ExplorerIntegration]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ExplorerIntegrationDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ContextMenu]}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ContextMenuDesc]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" IsChecked="{Binding ContextMenuEnabled}" 
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Startup]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.StartupDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.LaunchAtStartup]}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.LaunchAtStartupDesc]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" IsChecked="{Binding StartupEnabled}" 
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScheduledScanning]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScheduledScanningDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.EnableScheduledScan]}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.EnableScheduledScanDesc]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding ScheduleEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,6" IsEnabled="{Binding ScheduleEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Time]}" FontSize="13" Style="{StaticResource CardSubtitle}" 
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding ScheduleTime}" Width="100" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid IsEnabled="{Binding ScheduleEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ScheduleWeekly}" 
                                              Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Weekly]}" Foreground="{StaticResource SecondaryTextBrush}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding ScheduleDay}" Width="120" 
                                              Visibility="{Binding ScheduleWeekly, Converter={StaticResource BoolToVis}}">
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Sunday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Monday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Tuesday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Wednesday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Thursday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Friday]}"/>
                                        <ComboBoxItem Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Saturday]}"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOptionsTitle]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOptionsDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.MaxFileSizeLimit]}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.MaxFileSizeLimitDesc]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Text="{Binding MaxFileSizeMB, UpdateSourceTrigger=PropertyChanged}" Width="80" TextAlignment="Right"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Mb]}" Style="{StaticResource CardSubtitle}" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Separator Background="{StaticResource SeparatorBrush}" Margin="0,12"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanEngines]}" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2" Rows="7">
                            <CheckBox IsChecked="{Binding AllMatchMode}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.DeepScan]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding HeuristicAlerts}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Heuristic]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding AlertPua}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.DetectPua]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseArchives}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanArchives]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParsePe}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanPe]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParsePdf}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanPdf]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseOle2}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOle2]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseHtml}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanHtml]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseMail}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanMail]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseElf}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanElf]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseSwf}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanSwf]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding ParseRtf}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanRtf]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding AlertPdf}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.AlertPdf]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding AlertMacros}" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.AlertMacros]}" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.RealtimeProtection]}" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.RealtimeProtectionDesc]}" 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.EnableRealtime]}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.EnableRealtimeDesc]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding RealtimeEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Visibility="{Binding RealtimeEnabled, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.FilesScannedLabel]}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                    <TextBlock Text=" " FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                    <TextBlock Text="{Binding RealtimeScanned}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                </StackPanel>

                                 <StackPanel Margin="0,4,0,12" Visibility="{Binding RealtimeEnabled, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.RealtimeScope]}" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,4,0,8"/>
                                    
                                    <RadioButton IsChecked="{Binding RealtimeScanAll}" GroupName="RealtimeExtScope" Margin="0,0,0,10" VerticalContentAlignment="Top">
                                        <StackPanel Margin="6,-2,0,0">
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanAllExt]}" FontWeight="SemiBold" Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanAllExtDesc]}" 
                                                       TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    
                                    <RadioButton IsChecked="{Binding RealtimeScanOptimized}" GroupName="RealtimeExtScope" Margin="0,4,0,8" VerticalContentAlignment="Top">
                                        <StackPanel Margin="6,-2,0,0">
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOptExt]}" FontWeight="SemiBold" Foreground="White" FontSize="12"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOptExtDesc]}" 
                                                       TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.ScanOptExtList]}" 
                                                       TextWrapping="Wrap" FontSize="11" Foreground="#4A90E2" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </RadioButton>

                                    <Grid Margin="22,4,0,4" IsEnabled="{Binding RealtimeScanOptimized}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.CustomExt]}" FontSize="12" Foreground="{StaticResource DimTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding RealtimeCustomExtensions, UpdateSourceTrigger=PropertyChanged}" 
                                                 ToolTip="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.CustomExtToolTip]}" 
                                                 VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.WatchedFolders]}" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding WatchFolders}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Style="{StaticResource CardSubtitle}" 
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Style="{StaticResource SmallIconButton}"
                                                        Command="{Binding DataContext.RemoveWatchFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewWatchPath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Browse]}" Margin="6,0,6,0"
                                            Command="{Binding BrowseWatchFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                    <Button Grid.Column="2" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Add]}" 
                                            Command="{Binding AddWatchFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                </Grid>

                                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Exclusions]}" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding ExclusionPatterns}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Style="{StaticResource CardSubtitle}" 
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Style="{StaticResource SmallIconButton}"
                                                        Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.Add]}" Margin="6,0,0,0"
                                            Command="{Binding AddExclusionCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
