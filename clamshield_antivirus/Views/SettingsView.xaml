<UserControl x:Class="clamshield_antivirus.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Settings" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Configure ClamUI behavior and integrations" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Explorer Integration" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Add or remove the 'Scan with ClamUI' option from the Windows Explorer right-click context menu for files, folders, and drives." 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Context Menu" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Right-click files/folders and scan instantly" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" IsChecked="{Binding ContextMenuEnabled}" 
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Startup" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Automatically launch ClamUI when you sign in to Windows." 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Launch at Startup" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Start ClamUI automatically when you log in" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleButton Grid.Column="1" IsChecked="{Binding StartupEnabled}" 
                                              Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Scheduled Scanning" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Schedule automatic scans via Windows Task Scheduler. The app will scan all drives at the configured time." 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Enable Scheduled Scan" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Run scans automatically on a schedule" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding ScheduleEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,6" IsEnabled="{Binding ScheduleEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Time:" FontSize="13" Style="{StaticResource CardSubtitle}" 
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding ScheduleTime}" Width="100" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid IsEnabled="{Binding ScheduleEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ScheduleWeekly}" 
                                              Content="Weekly" Foreground="{StaticResource SecondaryTextBrush}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding ScheduleDay}" Width="120" 
                                              Visibility="{Binding ScheduleWeekly, Converter={StaticResource BoolToVis}}">
                                        <ComboBoxItem Content="Sunday"/>
                                        <ComboBoxItem Content="Monday"/>
                                        <ComboBoxItem Content="Tuesday"/>
                                        <ComboBoxItem Content="Wednesday"/>
                                        <ComboBoxItem Content="Thursday"/>
                                        <ComboBoxItem Content="Friday"/>
                                        <ComboBoxItem Content="Saturday"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Scan Options" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Configure limits and file types for scanning." 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Maximum File Size Limit" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="Skip scanning files exceeding this size limit" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Text="{Binding MaxFileSizeMB, UpdateSourceTrigger=PropertyChanged}" Width="80" TextAlignment="Right"/>
                                    <TextBlock Text=" MB" Style="{StaticResource CardSubtitle}" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Real-time Protection" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Monitor folders for new or modified files and scan them automatically for threats." 
                                   TextWrapping="Wrap" Style="{StaticResource CardSubtitle}" Margin="0,0,0,12"/>

                        <Border Style="{StaticResource InlineSettingRow}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Enable Real-time Monitoring" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="Automatically scan new and modified files" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding RealtimeEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="{Binding RealtimeScanned, StringFormat='Files scanned: {0}'}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,0,0,8"
                                           Visibility="{Binding RealtimeEnabled, Converter={StaticResource BoolToVis}}"/>

                                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="Watched Folders" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding WatchFolders}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Style="{StaticResource CardSubtitle}" 
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Style="{StaticResource SmallIconButton}"
                                                        Command="{Binding DataContext.RemoveWatchFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewWatchPath, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="Browse" Margin="6,0,6,0"
                                            Command="{Binding BrowseWatchFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                    <Button Grid.Column="2" Content="Add" 
                                            Command="{Binding AddWatchFolderCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                </Grid>

                                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,10"/>

                                <TextBlock Text="Exclusion Patterns" FontWeight="SemiBold" FontSize="13" Foreground="White" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding ExclusionPatterns}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Style="{StaticResource CardSubtitle}" 
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Style="{StaticResource SmallIconButton}"
                                                        Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewExclusion, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="Add" Margin="6,0,0,0"
                                            Command="{Binding AddExclusionCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
