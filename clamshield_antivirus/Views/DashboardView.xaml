<UserControl x:Class="clamshield_antivirus.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:local="clr-namespace:clamshield_antivirus.Views"
             xmlns:conv="clr-namespace:clamshield_antivirus.Converters"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>
        <conv:IssuesToColorConverter x:Key="IssuesToColorConverter"/>
        <conv:IssuesToIconConverter x:Key="IssuesToIconConverter"/>
        <conv:AuditWarningToVisConverter x:Key="AuditWarningToVisConverter"/>
        <conv:TimeframeEqualsConverter x:Key="TimeframeEqualsConverter"/>

        <Style x:Key="TimeframeTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (Unified Title & Subtitle) -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.Title]}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Scrollable Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- === SECTION 1: Status & Statistics Overview === -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Current Protection Status Monitor Card -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0" Padding="16">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Computer Monitor Graphics -->
                            <Grid Width="160" Height="110" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Canvas Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-5,0,0">
                                    <!-- Computer Monitor Frame -->
                                    <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="3.5" StrokeLineJoin="Round"
                                          Data="M 12,12 C 12,10 14,8 16,8 H 84 C 86,8 88,10 88,12 V 64 C 88,66 86,68 84,68 H 16 C 14,68 12,66 12,64 Z"/>
                                    <!-- Monitor stand neck -->
                                    <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="3.5" Fill="{StaticResource SecondaryTextBrush}"
                                          Data="M 43,68 L 38,86 H 62 L 57,68 Z"/>
                                    <!-- Monitor stand base -->
                                    <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="3.5"
                                          Data="M 30,86 H 70"/>

                                    <!-- Dynamic Status Badge Indicator Overlay (bottom-right edge of screen) -->
                                    <Grid Canvas.Left="68" Canvas.Top="48" Width="30" Height="30">
                                        <Ellipse Fill="{Binding StatusBgBrush}" Stroke="{Binding StatusBorderBrush}" StrokeThickness="2.5"/>

                                        <!-- Spinning loader path, only visible when loading -->
                                        <Path Data="M 15,5 A 10,10 0 1,1 5,15" Stroke="{Binding StatusSymbolBrush}" StrokeThickness="2.5" 
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stretch="Uniform" Margin="7" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                              Visibility="{Binding IsDatabaseLoading, Converter={StaticResource BoolToVis}}">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                            </Path.RenderTransform>
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDatabaseLoading}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="SpinnerStoryboard">
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                         From="0" To="360" Duration="0:0:1.2"
                                                                                         RepeatBehavior="Forever"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="SpinnerStoryboard"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>

                                        <!-- Normal status icon (checkmark/exclamation/cross), visible when not loading -->
                                        <Path Data="{Binding StatusSymbolPath}" Stroke="{Binding StatusSymbolBrush}" StrokeThickness="3" 
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stretch="Uniform" Margin="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Visibility="{Binding IsDatabaseLoading, Converter={StaticResource InvBoolToVis}}"/>
                                    </Grid>
                                </Canvas>
                            </Grid>

                            <!-- Status text info -->
                            <TextBlock Text="{Binding StatusTitle}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
                                       Foreground="{Binding StatusColorBrush}" Margin="0,4,0,2"/>

                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource DimTextBrush}" 
                                       TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,16"
                                       MaxWidth="240" Height="36"/>

                            <!-- Smart Scan Action Button -->
                            <Button Command="{Binding SmartScanCommand}" Style="{StaticResource AccentButton}" 
                                    IsEnabled="{Binding IsDatabaseLoading, Converter={StaticResource InvBool}}"
                                    HorizontalAlignment="Center" Padding="32,8" FontSize="13" Cursor="Hand" Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡ " FontSize="13" Foreground="White"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.SmartScan]}" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.SmartScanDesc]}" 
                                       FontSize="10" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Right Column: Statistics Overview -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Timeframe Tabs -->
                        <Grid Grid.Row="0" Margin="4,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Reports.SectionStatsTitle]}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>

                            <Border Grid.Column="1" Background="{StaticResource SidebarBgBrush}" CornerRadius="8" Padding="3" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TabDaily]}" Style="{StaticResource TimeframeTabStyle}" IsChecked="{Binding SelectedTimeframe, Converter={StaticResource TimeframeEqualsConverter}, ConverterParameter='Daily', Mode=TwoWay}"/>
                                    <RadioButton Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TabWeekly]}" Style="{StaticResource TimeframeTabStyle}" IsChecked="{Binding SelectedTimeframe, Converter={StaticResource TimeframeEqualsConverter}, ConverterParameter='Weekly', Mode=TwoWay}"/>
                                    <RadioButton Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TabMonthly]}" Style="{StaticResource TimeframeTabStyle}" IsChecked="{Binding SelectedTimeframe, Converter={StaticResource TimeframeEqualsConverter}, ConverterParameter='Monthly', Mode=TwoWay}"/>
                                    <RadioButton Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TabAllTime]}" Style="{StaticResource TimeframeTabStyle}" IsChecked="{Binding SelectedTimeframe, Converter={StaticResource TimeframeEqualsConverter}, ConverterParameter='All Time', Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 4 Statistics Cards in a Grid -->
                        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="4,0,0,0">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,6,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TotalScans]}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding TotalScans}" Style="{StaticResource StatNumber}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.ScansCompleted]}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="6,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.FilesScanned]}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding FilesScanned, StringFormat='{}{0:N0}'}" Style="{StaticResource StatNumber}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.ItemsInspected]}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,6,6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.ThreatsDetected]}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding ThreatsDetected}" Style="{StaticResource StatNumber}" 
                                               Foreground="{Binding ThreatsDetected, Converter={StaticResource StatusToColor}, ConverterParameter='infected'}" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.ThreatsIsolated]}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="6,6,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.AvgScanTime]}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding AvgDurationText}" Style="{StaticResource StatNumber}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Statistics.TimePerScan]}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Grid>

                <!-- === SECTION 2: Checklist Status Cards === -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: Real-time shield -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🛡️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.RealtimeProtection]}" 
                                           FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                <TextBlock Text="{Binding RealtimeStatusText}" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Column 2: Database Version -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,6,0" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📅" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.LastUpdate]}" 
                                           FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                <TextBlock Text="{Binding DbVersionText}" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Column 3: Last Scan Time -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,0,0" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏱️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.LastScanHeader]}" 
                                           FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                <TextBlock Text="{Binding LastScanText}" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,4,0,16"/>

                <!-- === SECTION 3: System Security Audit === -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Reports.SectionAuditTitle]}" Style="{StaticResource SectionTitle}"/>
                    <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Audit.Rerun]}" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding RunAuditCommand}" IsEnabled="{Binding IsAuditing, Converter={StaticResource InvBool}}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Audit Posture Summary Banner -->
                <Border CornerRadius="10" Padding="16" Margin="0,0,0,16"
                        Background="{Binding HasIssues, Converter={StaticResource IssuesToColorConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding HasIssues, Converter={StaticResource IssuesToIconConverter}}" FontSize="24" Margin="0,0,16,0" VerticalAlignment="Center"
                                   Foreground="#2D2D44"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SummaryText}" FontSize="15" FontWeight="Bold" Foreground="#2D2D44"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Audit Items List -->
                <ListBox ItemsSource="{Binding AuditItems}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AuditItem}">
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status Icon -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Status, Converter={StaticResource StatusToIcon}}" 
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}" 
                                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>

                                    <!-- Title & Description -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitle}"/>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CardSubtitle}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource BadgeStyle}" Padding="6,3" VerticalAlignment="Center"
                                            Background="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_bg'}"
                                            BorderBrush="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_border'}">
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}"/>
                                    </Border>

                                    <!-- Warning/Fail Suggestion -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                                Visibility="{Binding Status, Converter={StaticResource AuditWarningToVisConverter}}">
                                        <Separator Background="{StaticResource SeparatorBrush}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Suggestion}" Style="{StaticResource CardSubtitle}" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Copyable Command Box (Only if FixCommand exists) -->
                                    <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                          Visibility="{Binding FixCommand, Converter={StaticResource StringToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding FixCommand, Mode=OneWay}" 
                                                 FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                 Background="{StaticResource SidebarBgBrush}" Foreground="{StaticResource PrimaryTextBrush}"
                                                 Padding="10,6" IsReadOnly="True" BorderThickness="1,1,0,1"/>
                                        <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Audit.Copy]}" Style="{StaticResource SecondaryButton}" 
                                                Padding="12,6" BorderThickness="0,1,1,1"
                                                Click="CopyCommand_Click" CommandParameter="{Binding FixCommand}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>