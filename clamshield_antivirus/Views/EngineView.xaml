<UserControl x:Class="clamshield_antivirus.Views.EngineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:EngineViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.Title]}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- === SECTION 1: Database Update === -->
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.SectionDbTitle]}" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>

                <!-- Status Cards -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📦" Style="{StaticResource CardIcon}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.UpdaterStatus]}" Style="{StaticResource CardSubtitle}"/>
                                <TextBlock Text="{Binding StatusText}" Style="{StaticResource CardTitle}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.EngineActive]}" FontSize="11" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏰" Style="{StaticResource CardIcon}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.LastUpdate]}" Style="{StaticResource CardSubtitle}"/>
                                <TextBlock Text="{Binding LastUpdateTime}" Style="{StaticResource CardTitle}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.DefinitionsActive]}" FontSize="11" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Console Log + Info -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.ConsoleLog]}" Style="{StaticResource SectionTitle}"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding ProgressLog, Mode=OneWay}" 
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="12"
                                 Background="{StaticResource SidebarBgBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextChanged="TextBox_TextChanged"/>
                    </Grid>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.InfoTitle]}" Style="{StaticResource SectionTitle}" Margin="0,0,0,12"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.InstalledDbs]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding DbVersions}" Margin="0,0,0,16">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10" Margin="0,0,0,6" Background="{StaticResource SidebarBgBrush}" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DatabaseName}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Version, StringFormat='v{0}'}" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                                                        
                                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding SignatureCount, StringFormat='{}{0:N0} sigs'}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                                            <TextBlock Text=" • " FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                                            <TextBlock Text="{Binding BuildTime, StringFormat='yyyy-MM-dd'}" FontSize="11" Foreground="{StaticResource DimTextBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.CvdFormatTitle]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.CvdFormatDesc]}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.InfoFileFormatTitle]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.InfoFileFormatDesc]}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <Border Padding="8" Background="{StaticResource SidebarBgBrush}" CornerRadius="4" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.FormatLabel]}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.FormatName]}" FontSize="11" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.FormatSize]}" FontSize="11" Margin="0,2,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.FormatHash]}" FontSize="11" Margin="0,2,0,0" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.UpdateGuidelines]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.Guideline1]}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.Guideline2]}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Update/Cancel Buttons -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}">
                        <Grid Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Grid.RenderTransform>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:1.2" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Ellipse Stroke="{StaticResource BorderBrush}" StrokeThickness="2" Opacity="0.5"/>
                            <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2" StrokeDashArray="3 1.5"/>
                        </Grid>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.ProgressText]}" Style="{StaticResource CardSubtitle}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.CancelUpdate]}" Style="{StaticResource DangerButton}" Command="{Binding CancelUpdateCommand}" Margin="0,0,8,0"
                                Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.UpdateDefinitions]}" Style="{StaticResource AccentButton}" Command="{Binding UpdateCommand}" 
                                IsEnabled="{Binding CanUpdate}"
                                Visibility="{Binding IsUpdating, Converter={StaticResource InvBoolToVis}}"/>
                    </StackPanel>
                </Grid>

                <Separator Background="{StaticResource SeparatorBrush}" Margin="0,4,0,16"/>

                <!-- === SECTION 2: Components Status === -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.SectionCompTitle]}" Style="{StaticResource SectionTitle}"/>
                    <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.Refresh]}" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding RefreshCommand}" IsEnabled="{Binding IsChecking, Converter={StaticResource InvBool}}"
                            VerticalAlignment="Center"/>
                </Grid>

                <ListBox ItemsSource="{Binding Components}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ComponentStatus}">
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource SurfaceBrush}" Margin="0,0,12,0">
                                            <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitle}"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource CardSubtitle}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding ExecutablePath, StringFormat='Path: {0}'}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,4,0,0"
                                                       Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0" HorizontalAlignment="Right">
                                            <Border Style="{StaticResource BadgeStyle}" Padding="8,3"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_bg'}"
                                                    BorderBrush="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_border'}">
                                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="11" 
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Right" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{Binding Status, Converter={StaticResource StatusToIcon}}" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}" 
                                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border Grid.Row="1" Margin="0,10,0,0" Padding="12" CornerRadius="8" Background="{StaticResource SidebarBgBrush}"
                                            Visibility="{Binding IsInstalled, Converter={StaticResource InvBoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.GuideTitle]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.GuideStep1]}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.GuideStep2]}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.GuideStep3]}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Engine.GuideNote]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" FontStyle="Italic" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>