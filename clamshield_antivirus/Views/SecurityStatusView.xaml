<UserControl x:Class="clamshield_antivirus.Views.SecurityStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:SecurityStatusViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.Title]}" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Body (Centered Minimal Dashboard) -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="550">
            <StackPanel HorizontalAlignment="Center">
                
                <!-- Icon Area (Computer Monitor in neutral gray + dynamic Status Badge) -->
                <Grid Width="200" Height="130" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Canvas Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-10,0,0">
                        <!-- Computer Monitor Frame -->
                        <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="4" StrokeLineJoin="Round"
                              Data="M 15,15 C 15,12 17,10 20,10 H 100 C 103,10 105,12 105,15 V 80 C 105,83 103,85 100,85 H 20 C 17,85 15,83 15,80 Z"/>
                        <!-- Monitor stand neck -->
                        <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="4" Fill="{StaticResource SecondaryTextBrush}"
                              Data="M 52,85 L 45,108 H 75 L 68,85 Z"/>
                        <!-- Monitor stand base -->
                        <Path Stroke="{StaticResource SecondaryTextBrush}" StrokeThickness="4"
                              Data="M 35,108 H 85"/>
                        
                        <!-- Dynamic Status Badge Indicator Overlay (bottom-right edge of screen) -->
                        <Grid Canvas.Left="82" Canvas.Top="58" Width="36" Height="36">
                            <Ellipse Fill="{Binding StatusBgBrush}" Stroke="{Binding StatusBorderBrush}" StrokeThickness="3"/>
                            
                            <!-- Spinning loader path, only visible when loading -->
                            <Path Data="M 18,6 A 12,12 0 1,1 6,18" Stroke="{Binding StatusSymbolBrush}" StrokeThickness="3" 
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Margin="9" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                  Visibility="{Binding IsDatabaseLoading, Converter={StaticResource BoolToVis}}">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDatabaseLoading}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="SpinnerStoryboard">
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1.2"
                                                                             RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="SpinnerStoryboard"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>

                            <!-- Normal status icon (checkmark/exclamation/cross), visible when not loading -->
                            <Path Data="{Binding StatusSymbolPath}" Stroke="{Binding StatusSymbolBrush}" StrokeThickness="3.5" 
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Margin="9" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsDatabaseLoading, Converter={StaticResource InvBoolToVis}}"/>
                        </Grid>
                    </Canvas>
                </Grid>

                <!-- Status Text Summary -->
                <TextBlock Text="{Binding StatusTitle}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" 
                           Foreground="{Binding StatusColorBrush}" Margin="0,8,0,4"/>
                
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{StaticResource DimTextBrush}" 
                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Smart Scan Action Button -->
                <Button Command="{Binding SmartScanCommand}" Style="{StaticResource AccentButton}" 
                        IsEnabled="{Binding IsDatabaseLoading, Converter={StaticResource InvBool}}"
                        HorizontalAlignment="Center" Padding="48,12" FontSize="14" Cursor="Hand" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡ " FontSize="14" Foreground="White"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.SmartScan]}" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.SmartScanDesc]}" 
                           FontSize="11" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,32"/>

                <!-- Horizontal Divider -->
                <Border BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,24"/>

                <!-- Minimal Horizontal Details Grid -->
                <Grid Width="500" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: Real-time shield -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Settings.RealtimeProtection]}" 
                                   FontSize="11" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RealtimeStatusText}" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Column 2: Database Version -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Database.LastUpdate]}" 
                                   FontSize="11" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DbVersionText}" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Column 3: Last Scan Time -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[SecurityStatus.LastScanHeader]}" 
                                   FontSize="11" Foreground="{StaticResource DimTextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LastScanText}" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource PrimaryTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
