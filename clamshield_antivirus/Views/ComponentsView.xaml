<UserControl x:Class="clamshield_antivirus.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:ComponentsViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Title Section -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="ClamAV Components" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="Check the installation status of ClamAV core components" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="⟳ Refresh" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding RefreshCommand}" IsEnabled="{Binding IsChecking, Converter={StaticResource InvBool}}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Components List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Components}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ComponentStatus}">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Primary details -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon representation -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource SurfaceBrush}" Margin="0,0,16,0">
                                    <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Title and Executable Details -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitle}" FontSize="15"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CardSubtitle}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding ExecutablePath, StringFormat='Path: {0}'}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,4,0,0"
                                               Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Version / Installed indicator -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0" HorizontalAlignment="Right">
                                    <Border CornerRadius="4" Padding="8,4" BorderThickness="1"
                                            Background="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_bg'}"
                                            BorderBrush="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_border'}">
                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="11" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Right" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Status Badge Character -->
                                <TextBlock Grid.Column="3" Text="{Binding Status, Converter={StaticResource StatusToIcon}}" 
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}" 
                                           FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>

                            <!-- Setup instructions if missing -->
                            <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" CornerRadius="8" Background="{StaticResource SidebarBgBrush}"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource InvBoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="🔧 Signature Database Update Guide" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="1. Navigate to the 'Database' tab in the left sidebar menu." FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="2. Click the 'Update Definitions' button to download the latest ClamAV signatures." FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="3. The C# Engine will automatically compile, decompress, and load signatures into memory." FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="Note: An offline backup signature containing standard EICAR test patterns is built-in by default." FontSize="11" Foreground="{StaticResource DimTextBrush}" FontStyle="Italic" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
