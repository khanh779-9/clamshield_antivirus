<UserControl x:Class="clamshield_antivirus.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:ComponentsViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.Title]}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.Refresh]}" Style="{StaticResource SecondaryButton}" 
                    Command="{Binding RefreshCommand}" IsEnabled="{Binding IsChecking, Converter={StaticResource InvBool}}"
                    VerticalAlignment="Center"/>
        </Grid>

        <ListBox Grid.Row="1" ItemsSource="{Binding Components}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ComponentStatus}">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{StaticResource SurfaceBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitle}"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CardSubtitle}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding ExecutablePath, StringFormat='Path: {0}'}" FontSize="11" Foreground="{StaticResource DimTextBrush}" Margin="0,4,0,0"
                                               Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0" HorizontalAlignment="Right">
                                    <Border Style="{StaticResource BadgeStyle}" Padding="8,3"
                                            Background="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_bg'}"
                                            BorderBrush="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='card_border'}">
                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="11" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Right" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="{Binding Status, Converter={StaticResource StatusToIcon}}" 
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='badge_fg'}" 
                                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Grid.Row="1" Margin="0,10,0,0" Padding="12" CornerRadius="8" Background="{StaticResource SidebarBgBrush}"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource InvBoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.GuideTitle]}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.GuideStep1]}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.GuideStep2]}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.GuideStep3]}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Components.GuideNote]}" FontSize="11" Foreground="{StaticResource DimTextBrush}" FontStyle="Italic" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
