<UserControl x:Class="clamshield_antivirus.Views.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:clamshield_antivirus.ViewModels"
             xmlns:models="clr-namespace:clamshield_antivirus.Models"
             xmlns:helpers="clr-namespace:clamshield_antivirus.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             d:DataContext="{d:DesignInstance Type=vm:EventsViewModel}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.Title]}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.Subtitle]}" Style="{StaticResource SubheadingText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.ClearAll]}" Style="{StaticResource DangerButton}" Command="{Binding ClearAllCommand}" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                     Tag="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.SearchTag]}"
                     BorderBrush="{StaticResource BorderBrush}"/>
            <Button Grid.Column="1" Content="⟳" Style="{StaticResource IconButton}" FontSize="16" Margin="6,0,0,0"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource SidebarBgBrush}"
                        Visibility="{Binding Logs.Count, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="32" Opacity="0.35" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.NoHistory]}" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="0" ItemsSource="{Binding Logs}" SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding Logs.Count, Converter={StaticResource CountToVis}}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" Style="{StaticResource CardStyle}" Padding="10" Background="{StaticResource CardBgBrush}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardBgHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LogEntry}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="{Binding Status, Converter={StaticResource StatusToIcon}}" 
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                           FontSize="18" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Summary}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Style="{StaticResource CardSubtitle}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding ScanPath, Converter={StaticResource StringToVis}}">
                                        <Run Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.TargetsLabel], Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ScanPath, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border CornerRadius="3" Padding="4,1" Background="{StaticResource SurfaceBrush}" BorderThickness="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Type}" FontSize="9" Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </Border>
                                        <TextBlock Text="•" Foreground="{StaticResource DimTextBrush}" Margin="6,0" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontSize="10" Foreground="{StaticResource DimTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Load More button -->
                <Button Grid.Row="1" Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.LoadMore]}" 
                        Style="{StaticResource SecondaryButton}" Margin="0,8,0,0" HorizontalAlignment="Center"
                        Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMore, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <Grid Grid.Column="2" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8" Visibility="{Binding IsLogSelected, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.DetailTitle]}" Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.Copy]}" Style="{StaticResource SecondaryButton}" Padding="10,5" Command="{Binding CopyLogCommand}" Margin="0,0,6,0"/>
                        <Button Content="{Binding Source={x:Static helpers:LocalizationService.Instance}, Path=[Events.Export]}" Style="{StaticResource SecondaryButton}" Padding="10,5" Command="{Binding ExportLogCommand}"/>
                    </StackPanel>
                </Grid>

                <TextBox Grid.Row="1" 
                         Text="{Binding LogDetail, Mode=OneWay}"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="12"
                         Background="{StaticResource SidebarBgBrush}"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
